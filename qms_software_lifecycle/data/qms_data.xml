<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Sequence for Defects -->
        <record id="seq_qms_defect" model="ir.sequence">
            <field name="name">QMS Defect</field>
            <field name="code">qms.defect</field>
            <field name="prefix">DEF-</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Sequence for Change Requests -->
        <record id="seq_qms_change_request" model="ir.sequence">
            <field name="name">QMS Change Request</field>
            <field name="code">qms.change_request</field>
            <field name="prefix">CR-</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
