<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="module_category_qms" model="ir.module.category">
            <field name="name">Quality Management System (QMS)</field>
            <field name="description">Helps you manage software quality lifecycle.</field>
            <field name="sequence">10</field>
        </record>

        <record id="res_groups_privilege_qms" model="res.groups.privilege">
            <field name="name">Quality Management System (QMS)</field>
            <field name="category_id" ref="module_category_qms"/>
        </record>

        <record id="group_qms_read_only" model="res.groups">
            <field name="name">Read-Only (Auditor)</field>
            <field name="privilege_id" ref="res_groups_privilege_qms"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_qms_user" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="res_groups_privilege_qms"/>
            <field name="implied_ids" eval="[(4, ref('group_qms_read_only'))]"/>
        </record>

        <record id="group_qms_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="privilege_id" ref="res_groups_privilege_qms"/>
            <field name="implied_ids" eval="[(4, ref('group_qms_user'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

        <!-- Record Rules -->
        <record id="qms_project_company_rule" model="ir.rule">
            <field name="name">QMS Project Multi-Company</field>
            <field name="model_id" ref="model_qms_project"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <record id="qms_project_portal_rule" model="ir.rule">
            <field name="name">Portal Project: write access for partner/followers</field>
            <field name="model_id" ref="model_qms_project"/>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="domain_force">[
                '|',
                    ('partner_id', '=', user.partner_id.id),
                    ('message_partner_ids', 'in', [user.partner_id.id])
            ]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="qms_requirement_portal_rule" model="ir.rule">
            <field name="name">Portal Requirement: write access for partner/followers</field>
            <field name="model_id" ref="model_qms_requirement"/>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="domain_force">[
                '|', '|',
                    ('project_id.partner_id', '=', user.partner_id.id),
                    ('project_id.message_partner_ids', 'in', [user.partner_id.id]),
                    ('message_partner_ids', 'in', [user.partner_id.id])
            ]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="qms_defect_portal_rule" model="ir.rule">
            <field name="name">Portal Defect: write/create access for partner/followers</field>
            <field name="model_id" ref="model_qms_defect"/>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="domain_force">[
                '|', '|',
                    ('project_id.partner_id', '=', user.partner_id.id),
                    ('project_id.message_partner_ids', 'in', [user.partner_id.id]),
                    ('message_partner_ids', 'in', [user.partner_id.id])
            ]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>
    </data>
</odoo>
