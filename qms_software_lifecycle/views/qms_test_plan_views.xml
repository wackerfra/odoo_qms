<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_qms_test_plan_tree" model="ir.ui.view">
        <field name="name">qms.test_plan.tree</field>
        <field name="model">qms.test_plan</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="project_id"/>
                <field name="scope"/>
                <field name="release_id"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'active'" decoration-muted="state == 'archived'"/>
            </list>
        </field>
    </record>

    <record id="view_qms_test_plan_form" model="ir.ui.view">
        <field name="name">qms.test_plan.form</field>
        <field name="model">qms.test_plan</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_activate_plan" type="object" string="Activate" 
                            invisible="state != 'draft'" class="oe_highlight"/>
                    <button name="action_archive_plan" type="object" string="Archive" 
                            invisible="state != 'active'"/>
                    <button name="action_set_draft" type="object" string="Set to Draft" 
                            invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,archived"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Test Plan Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="scope"/>
                        </group>
                        <group>
                            <field name="release_id"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Strategy &amp; Description" name="strategy">
                            <group>
                                <field name="description"/>
                                <field name="strategy"/>
                            </group>
                        </page>
                        <page string="Test Cases" name="test_cases">
                            <field name="test_case_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="title"/>
                                    <field name="type"/>
                                    <field name="priority" widget="priority"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_qms_test_plan_search" model="ir.ui.view">
        <field name="name">qms.test_plan.search</field>
        <field name="model">qms.test_plan</field>
        <field name="arch" type="xml">
            <search string="Search Test Plans">
                <field name="name" string="Test Plan Name"/>
                <field name="project_id" string="Project"/>
                <field name="release_id" string="Release"/>
                <filter string="Active Test Plans" name="filter_state_active" domain="[('state', '=', 'active')]"/>
                <filter string="Archived" name="filter_inactive" domain="[('active', '=', False)]"/>
                <group>
                    <filter string="Project" name="filter_group_by_project" context="{'group_by': 'project_id'}"/>
                    <filter string="Release" name="filter_group_by_release" context="{'group_by': 'release_id'}"/>
                    <filter string="Status" name="filter_group_by_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_qms_test_plan" model="ir.actions.act_window">
        <field name="name">Test Plans</field>
        <field name="res_model">qms.test_plan</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first test plan!
            </p>
        </field>
    </record>
</odoo>
