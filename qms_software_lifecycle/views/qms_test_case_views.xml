<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_qms_test_case_tree" model="ir.ui.view">
        <field name="name">qms.test_case.tree</field>
        <field name="model">qms.test_case</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="title"/>
                <field name="project_id"/>
                <field name="type"/>
                <field name="priority" widget="priority"/>
                <field name="state" widget="badge" decoration-info="state in ('draft', 'review')" decoration-success="state == 'approved'" decoration-muted="state == 'obsolete'"/>
            </list>
        </field>
    </record>

    <record id="view_qms_test_case_form" model="ir.ui.view">
        <field name="name">qms.test_case.form</field>
        <field name="model">qms.test_case</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_review" type="object" string="Submit for Review" 
                            invisible="state != 'draft'" class="oe_highlight"/>
                    <button name="action_approve" type="object" string="Approve" 
                            invisible="state != 'review'" class="oe_highlight" groups="qms_software_lifecycle.group_qms_manager"/>
                    <button name="action_obsolete" type="object" string="Obsolete" 
                            invisible="state != 'approved'"/>
                    <button name="action_set_draft" type="object" string="Set to Draft" 
                            invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,review,approved,obsolete"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="TC-001"/>
                        </h1>
                        <h2>
                            <field name="title" placeholder="Test Case Title"/>
                        </h2>
                    </div>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="type"/>
                            <field name="priority" widget="priority"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Test Definition" name="definition">
                            <group>
                                <field name="pre_conditions" placeholder="Describe pre-conditions..."/>
                                <field name="test_steps" placeholder="Describe test steps..."/>
                                <field name="expected_results" placeholder="Describe expected results..."/>
                            </group>
                        </page>
                        <page string="Traceability" name="traceability">
                            <group>
                                <field name="requirement_ids" widget="many2many_tags"/>
                                <field name="release_ids" widget="many2many_tags"/>
                                <field name="defect_ids" widget="many2many_tags" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_qms_test_case_graph" model="ir.ui.view">
        <field name="name">qms.test_case.graph</field>
        <field name="model">qms.test_case</field>
        <field name="arch" type="xml">
            <graph string="Test Cases Analysis" type="bar" sample="1">
                <field name="project_id"/>
                <field name="state"/>
            </graph>
        </field>
    </record>

    <record id="view_qms_test_case_pivot" model="ir.ui.view">
        <field name="name">qms.test_case.pivot</field>
        <field name="model">qms.test_case</field>
        <field name="arch" type="xml">
            <pivot string="Test Cases Analysis" sample="1">
                <field name="project_id" type="row"/>
                <field name="type" type="col"/>
                <field name="state" type="col"/>
            </pivot>
        </field>
    </record>

    <record id="view_qms_test_case_search" model="ir.ui.view">
        <field name="name">qms.test_case.search</field>
        <field name="model">qms.test_case</field>
        <field name="arch" type="xml">
            <search string="Search Test Cases">
                <field name="name" string="Test Case ID"/>
                <field name="title" string="Title"/>
                <field name="project_id" string="Project"/>
                <field name="type" string="Type"/>
                <filter string="Approved" name="filter_approved" domain="[('state', '=', 'approved')]"/>
                <group>
                    <filter string="Project" name="filter_group_by_project" context="{'group_by': 'project_id'}"/>
                    <filter string="Type" name="filter_group_by_type" context="{'group_by': 'type'}"/>
                    <filter string="Status" name="filter_group_by_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_qms_test_case" model="ir.actions.act_window">
        <field name="name">Test Cases</field>
        <field name="res_model">qms.test_case</field>
        <field name="view_mode">list,form,pivot,graph</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define your first test case!
            </p>
        </field>
    </record>
</odoo>
