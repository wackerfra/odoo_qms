<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_qms_change_request_tree" model="ir.ui.view">
        <field name="name">qms.change_request.tree</field>
        <field name="model">qms.change_request</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="title"/>
                <field name="project_id"/>
                <field name="type"/>
                <field name="state" widget="badge" decoration-info="state in ('draft', 'review')" decoration-warning="state == 'progress'" decoration-success="state in ('approved', 'implemented')" decoration-danger="state == 'rejected'"/>
            </list>
        </field>
    </record>

    <record id="view_qms_change_request_kanban" model="ir.ui.view">
        <field name="name">qms.change_request.kanban</field>
        <field name="model">qms.change_request</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" sample="1">
                <field name="name"/>
                <field name="title"/>
                <field name="type"/>
                <templates>
                    <t t-name="card">
                        <main>
                            <div class="d-flex mb-1">
                                <strong class="o_kanban_record_title text-truncate">
                                    <field name="name"/>: <field name="title"/>
                                </strong>
                            </div>
                            <div class="text-muted small">
                                <field name="type"/>
                            </div>
                        </main>
                        <footer class="pt-1 text-end">
                            <field name="activity_ids" widget="kanban_activity"/>
                        </footer>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_qms_change_request_form" model="ir.ui.view">
        <field name="name">qms.change_request.form</field>
        <field name="model">qms.change_request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_review" type="object" string="Submit for Review" 
                            invisible="state != 'draft'" class="oe_highlight"/>
                    <button name="action_approve" type="object" string="Approve" 
                            invisible="state != 'review'" class="oe_highlight" groups="qms_software_lifecycle.group_qms_manager"/>
                    <button name="action_reject" type="object" string="Reject" 
                            invisible="state != 'review'" groups="qms_software_lifecycle.group_qms_manager"/>
                    <button name="action_progress" type="object" string="Start Implementation" 
                            invisible="state != 'approved'" class="oe_highlight"/>
                    <button name="action_implement" type="object" string="Mark Implemented" 
                            invisible="state != 'progress'" class="oe_highlight"/>
                    <button name="action_set_draft" type="object" string="Set to Draft" 
                            invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,review,approved,progress,implemented"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                        <h2>
                            <field name="title" placeholder="Change Request Title"/>
                        </h2>
                    </div>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="type"/>
                        </group>
                        <group>
                            <field name="impact_cost"/>
                            <field name="approver_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description" placeholder="Describe the change request..."/>
                        </page>
                        <page string="Impact Analysis" name="impact">
                            <group>
                                <field name="impact_scope" placeholder="Describe scope impact..."/>
                                <field name="impact_risk" placeholder="Describe risk impact..."/>
                                <field name="impact_schedule" placeholder="Describe schedule impact..."/>
                            </group>
                        </page>
                        <page string="Traceability" name="traceability">
                            <group>
                                <field name="requirement_ids" widget="many2many_tags"/>
                                <field name="defect_ids" widget="many2many_tags"/>
                                <field name="release_ids" widget="many2many_tags"/>
                                <field name="document_ids" widget="many2many_tags"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_qms_change_request_search" model="ir.ui.view">
        <field name="name">qms.change_request.search</field>
        <field name="model">qms.change_request</field>
        <field name="arch" type="xml">
            <search string="Search Change Requests">
                <field name="name" string="CR ID"/>
                <field name="title" string="Title"/>
                <field name="project_id" string="Project"/>
                <filter string="Approved" name="filter_approved" domain="[('state', '=', 'approved')]"/>
                <filter string="In Progress" name="filter_progress" domain="[('state', '=', 'progress')]"/>
                <group>
                    <filter string="Project" name="filter_group_by_project" context="{'group_by': 'project_id'}"/>
                    <filter string="Type" name="filter_group_by_type" context="{'group_by': 'type'}"/>
                    <filter string="Status" name="filter_group_by_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_qms_change_request" model="ir.actions.act_window">
        <field name="name">Change Requests</field>
        <field name="res_model">qms.change_request</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first change request!
            </p>
        </field>
    </record>
</odoo>
