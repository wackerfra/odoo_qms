<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_qms_defect_tree" model="ir.ui.view">
        <field name="name">qms.defect.tree</field>
        <field name="model">qms.defect</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="title"/>
                <field name="project_id"/>
                <field name="severity" widget="badge" decoration-danger="severity in ('3', '4')" decoration-warning="severity == '2'" decoration-info="severity == '1'" decoration-muted="severity == '0'"/>
                <field name="priority" widget="priority"/>
                <field name="user_id"/>
                <field name="state" widget="badge" decoration-info="state in ('new', 'analysis')" decoration-warning="state == 'progress'" decoration-success="state in ('resolved', 'verified', 'closed')" decoration-danger="state == 'rejected'"/>
            </list>
        </field>
    </record>

    <record id="view_qms_defect_kanban" model="ir.ui.view">
        <field name="name">qms.defect.kanban</field>
        <field name="model">qms.defect</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" sample="1">
                <field name="name"/>
                <field name="title"/>
                <field name="severity"/>
                <field name="priority"/>
                <templates>
                    <t t-name="card">
                        <main>
                            <div class="d-flex mb-1">
                                <strong class="o_kanban_record_title text-truncate">
                                    <field name="name"/>: <field name="title"/>
                                </strong>
                            </div>
                            <div>
                                <field name="severity" widget="label_selection" options="{'classes': {'0': 'default', '1': 'info', '2': 'warning', '3': 'danger', '4': 'danger'}}"/>
                            </div>
                        </main>
                        <footer class="pt-1">
                            <div class="d-flex align-items-center gap-1">
                                <field name="priority" widget="priority"/>
                                <field name="user_id" widget="many2one_avatar_user" class="ms-auto"/>
                            </div>
                        </footer>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_qms_defect_form" model="ir.ui.view">
        <field name="name">qms.defect.form</field>
        <field name="model" >qms.defect</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_analyze" type="object" string="Analyze" 
                            invisible="state != 'new'" class="oe_highlight"/>
                    <button name="action_progress" type="object" string="Start Fix" 
                            invisible="state != 'analysis'" class="oe_highlight"/>
                    <button name="action_resolve" type="object" string="Resolve" 
                            invisible="state != 'progress'" class="oe_highlight"/>
                    <button name="action_verify" type="object" string="Verify" 
                            invisible="state != 'resolved'" class="oe_highlight"/>
                    <button name="action_close" type="object" string="Close" 
                            invisible="state != 'verified'"/>
                    <button name="action_reject" type="object" string="Reject" 
                            invisible="state not in ['new', 'analysis', 'progress']"/>
                    <button name="action_set_draft" type="object" string="Set to New" 
                            invisible="state == 'new'"/>
                    <field name="state" widget="statusbar" statusbar_visible="new,analysis,progress,resolved,verified,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                        <h2>
                            <field name="title" placeholder="Defect Title"/>
                        </h2>
                    </div>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="severity"/>
                            <field name="priority" widget="priority"/>
                        </group>
                        <group>
                            <field name="user_id"/>
                            <field name="test_run_line_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description" placeholder="Describe the defect..."/>
                        </page>
                        <page string="CAPA &amp; Root Cause" name="capa">
                            <group>
                                <field name="root_cause" placeholder="Identify the root cause..."/>
                                <field name="corrective_action" placeholder="Describe the corrective action taken..."/>
                                <field name="preventive_action" placeholder="Describe the preventive action (CAPA)..."/>
                            </group>
                        </page>
                        <page string="Traceability" name="traceability">
                            <group>
                                <field name="requirement_ids" widget="many2many_tags"/>
                                <field name="test_case_ids" widget="many2many_tags"/>
                                <field name="release_ids" widget="many2many_tags"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_qms_defect_graph" model="ir.ui.view">
        <field name="name">qms.defect.graph</field>
        <field name="model">qms.defect</field>
        <field name="arch" type="xml">
            <graph string="Defects Analysis" type="bar" sample="1">
                <field name="project_id"/>
                <field name="state"/>
            </graph>
        </field>
    </record>

    <record id="view_qms_defect_pivot" model="ir.ui.view">
        <field name="name">qms.defect.pivot</field>
        <field name="model">qms.defect</field>
        <field name="arch" type="xml">
            <pivot string="Defects Analysis" sample="1">
                <field name="project_id" type="row"/>
                <field name="severity" type="col"/>
                <field name="state" type="col"/>
            </pivot>
        </field>
    </record>

    <record id="view_qms_defect_search" model="ir.ui.view">
        <field name="name">qms.defect.search</field>
        <field name="model">qms.defect</field>
        <field name="arch" type="xml">
            <search string="Search Defects">
                <field name="name" string="Defect ID"/>
                <field name="title" string="Title"/>
                <field name="project_id" string="Project"/>
                <field name="user_id" string="Assignee"/>
                <filter string="My Defects" name="filter_my_defects" domain="[('user_id', '=', uid)]"/>
                <filter string="Open" name="filter_open" domain="[('state', 'not in', ('resolved', 'verified', 'closed', 'rejected'))]"/>
                <filter string="High Severity" name="filter_high_severity" domain="[('severity', 'in', ('3', '4'))]"/>
                <group>
                    <filter string="Project" name="filter_group_by_project" context="{'group_by': 'project_id'}"/>
                    <filter string="Assignee" name="filter_group_by_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Severity" name="filter_group_by_severity" context="{'group_by': 'severity'}"/>
                    <filter string="Status" name="filter_group_by_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_qms_defect" model="ir.actions.act_window">
        <field name="name">Defects</field>
        <field name="res_model">qms.defect</field>
        <field name="view_mode">kanban,list,form,pivot,graph</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Report your first defect!
            </p>
        </field>
    </record>
</odoo>
