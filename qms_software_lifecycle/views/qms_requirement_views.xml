<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_qms_requirement_tree" model="ir.ui.view">
        <field name="name">qms.requirement.tree</field>
        <field name="model">qms.requirement</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="title"/>
                <field name="project_id"/>
                <field name="user_id"/>
                <field name="type"/>
                <field name="priority" widget="priority"/>
                <field name="state" widget="badge" decoration-info="state in ('draft', 'review')" decoration-success="state in ('approved', 'implemented', 'verified')" decoration-danger="state == 'rejected'"/>
            </list>
        </field>
    </record>

    <record id="view_qms_requirement_kanban" model="ir.ui.view">
        <field name="name">qms.requirement.kanban</field>
        <field name="model">qms.requirement</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" sample="1">
                <field name="name"/>
                <field name="title"/>
                <field name="priority"/>
                <field name="type"/>
                <templates>
                    <t t-name="card">
                        <main>
                            <div class="d-flex mb-1">
                                <strong class="o_kanban_record_title text-truncate">
                                    [<field name="name"/>] <field name="title"/>
                                </strong>
                            </div>
                            <div class="text-muted small">
                                <field name="type"/>
                            </div>
                        </main>
                        <footer class="pt-1">
                            <div class="d-flex align-items-center gap-1">
                                <field name="priority" widget="priority"/>
                                <field name="activity_ids" widget="kanban_activity" class="ms-auto"/>
                            </div>
                        </footer>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_qms_requirement_form" model="ir.ui.view">
        <field name="name">qms.requirement.form</field>
        <field name="model">qms.requirement</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_review" type="object" string="Submit for Review" 
                            invisible="state != 'draft'" class="oe_highlight"/>
                    <button name="action_approve" type="object" string="Approve" 
                            invisible="state != 'review'" class="oe_highlight" groups="qms_software_lifecycle.group_qms_manager"/>
                    <button name="action_reject" type="object" string="Reject" 
                            invisible="state != 'review'" groups="qms_software_lifecycle.group_qms_manager"/>
                    <button name="action_implement" type="object" string="Mark Implemented" 
                            invisible="state != 'approved'" class="oe_highlight"/>
                    <button name="action_verify" type="object" string="Verify" 
                            invisible="state != 'implemented'" class="oe_highlight"/>
                    <button name="action_set_draft" type="object" string="Set to Draft" 
                            invisible="state in ['draft', 'approved', 'verified']"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,review,approved,implemented,verified"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="REQ-001"/>
                        </h1>
                        <h2>
                            <field name="title" placeholder="Requirement Title"/>
                        </h2>
                    </div>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="user_id"/>
                            <field name="type"/>
                            <field name="priority" widget="priority"/>
                            <field name="risk_level"/>
                        </group>
                        <group>
                            <field name="version"/>
                            <field name="parent_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description" placeholder="Describe the requirement..."/>
                        </page>
                        <page string="Acceptance Criteria" name="acceptance">
                            <field name="acceptance_criteria" placeholder="Define acceptance criteria..."/>
                        </page>
                        <page string="Traceability" name="traceability">
                            <group>
                                <field name="specification_ids" widget="many2many_tags"/>
                                <field name="test_case_ids" widget="many2many_tags"/>
                                <field name="defect_ids" widget="many2many_tags" readonly="1"/>
                                <field name="change_request_ids" widget="many2many_tags"/>
                                <field name="release_ids" widget="many2many_tags"/>
                                <field name="risk_ids" widget="many2many_tags"/>
                                <field name="document_ids" widget="many2many_tags"/>
                            </group>
                        </page>
                        <page string="Child Requirements" name="children">
                            <field name="child_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="title"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_qms_requirement_graph" model="ir.ui.view">
        <field name="name">qms.requirement.graph</field>
        <field name="model">qms.requirement</field>
        <field name="arch" type="xml">
            <graph string="Requirements Analysis" type="bar" sample="1">
                <field name="project_id"/>
                <field name="state"/>
            </graph>
        </field>
    </record>

    <record id="view_qms_requirement_pivot" model="ir.ui.view">
        <field name="name">qms.requirement.pivot</field>
        <field name="model">qms.requirement</field>
        <field name="arch" type="xml">
            <pivot string="Requirements Analysis" sample="1">
                <field name="project_id" type="row"/>
                <field name="state" type="col"/>
            </pivot>
        </field>
    </record>

    <record id="view_qms_requirement_search" model="ir.ui.view">
        <field name="name">qms.requirement.search</field>
        <field name="model">qms.requirement</field>
        <field name="arch" type="xml">
            <search string="Search Requirements">
                <field name="name" string="Requirement ID"/>
                <field name="title" string="Title"/>
                <field name="project_id" string="Project"/>
                <field name="user_id" string="Responsible"/>
                <filter string="My Requirements" name="filter_my_reqs" domain="[('user_id', '=', uid)]"/>
                <filter string="Approved" name="filter_approved" domain="[('state', '=', 'approved')]"/>
                <filter string="Implemented" name="filter_implemented" domain="[('state', '=', 'implemented')]"/>
                <group>
                    <filter string="Project" name="filter_group_by_project" context="{'group_by': 'project_id'}"/>
                    <filter string="Responsible" name="filter_group_by_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Status" name="filter_group_by_state" context="{'group_by': 'state'}"/>
                    <filter string="Type" name="filter_group_by_type" context="{'group_by': 'type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_qms_requirement" model="ir.actions.act_window">
        <field name="name">Requirements</field>
        <field name="res_model">qms.requirement</field>
        <field name="view_mode">kanban,list,form,pivot,graph</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define your first software requirement!
            </p>
        </field>
    </record>
</odoo>
