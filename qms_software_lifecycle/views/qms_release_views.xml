<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_qms_release_tree" model="ir.ui.view">
        <field name="name">qms.release.tree</field>
        <field name="model">qms.release</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="project_id"/>
                <field name="release_date"/>
                <field name="type"/>
                <field name="state" widget="badge" decoration-info="state in ('planned', 'testing')" decoration-success="state == 'released'" decoration-warning="state == 'ready'" decoration-muted="state == 'deprecated'"/>
            </list>
        </field>
    </record>

    <record id="view_qms_release_form" model="ir.ui.view">
        <field name="name">qms.release.form</field>
        <field name="model">qms.release</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_test" type="object" string="Start Testing" 
                            invisible="state != 'planned'" class="oe_highlight"/>
                    <button name="action_ready" type="object" string="Mark Ready" 
                            invisible="state != 'testing'" class="oe_highlight"/>
                    <button name="action_release" type="object" string="Release" 
                            invisible="state != 'ready'" class="oe_highlight" groups="qms_software_lifecycle.group_qms_manager"/>
                    <button name="action_deprecate" type="object" string="Deprecate" 
                            invisible="state != 'released'"/>
                    <button name="action_set_planned" type="object" string="Set to Planned" 
                            invisible="state == 'planned'"/>
                    <field name="state" widget="statusbar" statusbar_visible="planned,testing,ready,released"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="v1.0.0"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="type"/>
                        </group>
                        <group>
                            <field name="release_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Release Notes" name="notes">
                            <field name="release_notes" placeholder="Write release notes..."/>
                        </page>
                        <page string="Scope" name="scope">
                            <group string="Included Requirements">
                                <field name="requirement_ids" widget="many2many_tags" nolabel="1"/>
                            </group>
                            <group string="Resolved Defects">
                                <field name="defect_ids" widget="many2many_tags" nolabel="1"/>
                            </group>
                            <group string="Implemented Change Requests">
                                <field name="change_request_ids" widget="many2many_tags" nolabel="1"/>
                            </group>
                        </page>
                        <page string="Testing &amp; Documentation" name="testing">
                            <group string="Test Plans">
                                <field name="test_plan_ids" widget="many2many_tags" nolabel="1"/>
                            </group>
                            <group string="Documents">
                                <field name="document_ids" widget="many2many_tags" nolabel="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_qms_release_graph" model="ir.ui.view">
        <field name="name">qms.release.graph</field>
        <field name="model">qms.release</field>
        <field name="arch" type="xml">
            <graph string="Releases Analysis" type="bar" sample="1">
                <field name="project_id"/>
                <field name="state"/>
            </graph>
        </field>
    </record>

    <record id="view_qms_release_pivot" model="ir.ui.view">
        <field name="name">qms.release.pivot</field>
        <field name="model">qms.release</field>
        <field name="arch" type="xml">
            <pivot string="Releases Analysis" sample="1">
                <field name="project_id" type="row"/>
                <field name="type" type="col"/>
                <field name="state" type="col"/>
            </pivot>
        </field>
    </record>

    <record id="view_qms_release_search" model="ir.ui.view">
        <field name="name">qms.release.search</field>
        <field name="model">qms.release</field>
        <field name="arch" type="xml">
            <search string="Search Releases">
                <field name="name" string="Release Name"/>
                <field name="project_id" string="Project"/>
                <filter string="Released" name="filter_released" domain="[('state', '=', 'released')]"/>
                <filter string="Planned" name="filter_planned" domain="[('state', '=', 'planned')]"/>
                <group>
                    <filter string="Project" name="filter_group_by_project" context="{'group_by': 'project_id'}"/>
                    <filter string="Type" name="filter_group_by_type" context="{'group_by': 'type'}"/>
                    <filter string="Status" name="filter_group_by_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_qms_release" model="ir.actions.act_window">
        <field name="name">Releases</field>
        <field name="res_model">qms.release</field>
        <field name="view_mode">list,form,pivot,graph</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Plan your first release!
            </p>
        </field>
    </record>
</odoo>
