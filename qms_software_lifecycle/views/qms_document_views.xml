<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_qms_document_tree" model="ir.ui.view">
        <field name="name">qms.document.tree</field>
        <field name="model">qms.document</field>
        <field name="arch" type="xml">
            <list>
                <field name="title"/>
                <field name="project_id"/>
                <field name="type"/>
                <field name="version"/>
                <field name="state" widget="badge" decoration-info="state in ('draft', 'review')" decoration-success="state == 'approved'" decoration-muted="state == 'obsolete'"/>
            </list>
        </field>
    </record>

    <record id="view_qms_document_form" model="ir.ui.view">
        <field name="name">qms.document.form</field>
        <field name="model">qms.document</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_review" type="object" string="Submit for Review" 
                            invisible="state != 'draft'" class="oe_highlight"/>
                    <button name="action_approve" type="object" string="Approve" 
                            invisible="state != 'review'" class="oe_highlight" groups="qms_software_lifecycle.group_qms_manager"/>
                    <button name="action_obsolete" type="object" string="Obsolete" 
                            invisible="state != 'approved'"/>
                    <button name="action_set_draft" type="object" string="Set to Draft" 
                            invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,review,approved,obsolete"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="title" placeholder="Document Title"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="type"/>
                            <field name="template_id"/>
                        </group>
                        <group>
                            <field name="version"/>
                            <field name="file" filename="file_name"/>
                            <field name="file_name" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Content" name="content">
                            <field name="content" placeholder="Write your document content here..."/>
                        </page>
                        <page string="Traceability" name="traceability">
                            <group>
                                <field name="requirement_ids" widget="many2many_tags"/>
                                <field name="test_plan_ids" widget="many2many_tags"/>
                                <field name="release_ids" widget="many2many_tags"/>
                                <field name="change_request_ids" widget="many2many_tags"/>
                                <field name="specification_ids" widget="many2many_tags"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_qms_document_search" model="ir.ui.view">
        <field name="name">qms.document.search</field>
        <field name="model">qms.document</field>
        <field name="arch" type="xml">
            <search string="Search Documents">
                <field name="title" string="Title"/>
                <field name="project_id" string="Project"/>
                <field name="type" string="Type"/>
                <filter string="Approved" name="filter_approved" domain="[('state', '=', 'approved')]"/>
                <filter string="User Manuals" name="filter_user_manuals" domain="[('type', '=', 'user_manual')]"/>
                <group>
                    <filter string="Project" name="filter_group_by_project" context="{'group_by': 'project_id'}"/>
                    <filter string="Type" name="filter_group_by_type" context="{'group_by': 'type'}"/>
                    <filter string="Status" name="filter_group_by_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_qms_document" model="ir.actions.act_window">
        <field name="name">Documents</field>
        <field name="res_model">qms.document</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Manage your QMS documents!
            </p>
        </field>
    </record>

    <record id="action_qms_user_manual" model="ir.actions.act_window">
        <field name="name">User Manuals</field>
        <field name="res_model">qms.document</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('type', '=', 'user_manual')]</field>
        <field name="context">{'default_type': 'user_manual'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first user manual!
            </p>
        </field>
    </record>
</odoo>
